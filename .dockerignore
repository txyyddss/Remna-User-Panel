# Git and local state
.gitignore
.gitattributes
.github
.env
.env.*
!.env.example
scratch/
scratch_*
.claude/
*.local.*

# Dependencies and build outputs
node_modules/
frontend/node_modules/
frontend-nginx-dist/
bin/
dist/
coverage.out
*.test
*.prof

# Runtime-only data
data/*
!data/tariffs.example.json
!data/locales-overrides.example.json

# Local compose and temp files
docker-compose.yml
deploy/compose/*.yml
tmp/

# WebApp build artifacts regenerated inside Docker
internal/webassets/templates/subscription_webapp.css
internal/webassets/templates/subscription_webapp.js
